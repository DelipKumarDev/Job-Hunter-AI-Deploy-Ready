# ══════════════════════════════════════════════════════════════
# Job Hunter AI — Production Environment Variables
# Copy to .env and fill ALL values before starting
#
# NEVER commit this file. Add .env to .gitignore.
# Store secrets in AWS Secrets Manager or GitHub Secrets.
# ══════════════════════════════════════════════════════════════

# ── Image versioning ──────────────────────────────────────────
IMAGE_TAG=latest

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=jobhunter
POSTGRES_USER=jhuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS

# Use pgbouncer for connection pooling in production
DATABASE_URL=postgresql://jhuser:CHANGE_ME_STRONG_PASSWORD_32CHARS@pgbouncer:5432/jobhunter

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_32CHARS
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_32CHARS@redis:6379
REDIS_QUEUE_PREFIX=jhq

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_64_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_TOKEN_SECRET_MIN_64_CHARS
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Application ───────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3001
CORS_ORIGINS=https://jobhunter.ai,https://www.jobhunter.ai
NEXT_PUBLIC_API_URL=https://api.jobhunter.ai

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Voyage AI (embeddings) ────────────────────────────────────
VOYAGE_API_KEY=CHANGE_ME

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=job-hunter-prod-assets
AWS_ACCOUNT_ID=123456789012

# ── Gmail OAuth2 ──────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=CHANGE_ME
GMAIL_REDIRECT_URI=https://api.jobhunter.ai/api/v1/email/oauth/callback

# ── WhatsApp Cloud API ────────────────────────────────────────
# Create at: https://developers.facebook.com/apps/
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_WHATSAPP_WEBHOOK_VERIFY_TOKEN
WHATSAPP_ACCESS_TOKEN=CHANGE_ME_WHATSAPP_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_BUSINESS_ACCOUNT_ID=CHANGE_ME

# ── Stripe ───────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_ID_YEARLY=price_CHANGE_ME

# ── Application Bot ───────────────────────────────────────────
# Residential proxy pool for bot stealth
# Format: user:pass@host:port,user:pass@host:port,...
PROXY_POOL=CHANGE_ME_PROXY_LIST
BOT_CONCURRENCY=2

# ── Worker concurrency ────────────────────────────────────────
SCRAPER_CONCURRENCY=3
AI_CONCURRENCY=10
EMAIL_CONCURRENCY=5
NOTIFICATION_CONCURRENCY=20
RESUME_CONCURRENCY=5
PREP_CONCURRENCY=3

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Encryption (for stored email tokens) ─────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── Slack notifications ───────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
