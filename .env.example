# ============================================================
# JOB HUNTER AI AGENT — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── APP ──────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="Job Hunter AI"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
MOBILE_DEEP_LINK_SCHEME=jobhunterai

# ─── SECURITY ─────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-here-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-here
JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_KEY=your-32-byte-hex-key-for-aes-256-gcm
COOKIE_SECRET=your-cookie-signing-secret

# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL=postgresql://jobhunter:password@localhost:5432/jobhunterdb
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_LOG_QUERIES=false

# ─── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379
REDIS_QUEUE_PREFIX=jhq
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=changeme

# ─── AWS ──────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=job-hunter-ai-files
S3_REGION=us-east-1
CLOUDFRONT_URL=https://your-cloudfront-id.cloudfront.net

# ─── AI (Anthropic / OpenAI) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# ─── OAUTH ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── GMAIL API ────────────────────────────────────────────
GMAIL_CLIENT_ID=your-gmail-api-client-id
GMAIL_CLIENT_SECRET=your-gmail-api-secret
GMAIL_REDIRECT_URI=http://localhost:4000/email/oauth/callback

# ─── WHATSAPP (Meta Cloud API) ────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-meta-permanent-access-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-ba-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-custom-webhook-verify-token
WHATSAPP_API_URL=https://graph.facebook.com/v19.0

# ─── FIREBASE (Push Notifications) ───────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-admin@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key\n-----END PRIVATE KEY-----\n"

# ─── STRIPE (Billing) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_STARTER=price_your-starter-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_ENTERPRISE=price_your-enterprise-price-id

# ─── PROXY SERVICE (Anti-detection) ──────────────────────
PROXY_PROVIDER=brightdata
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password
PROXY_POOL_SIZE=20

# ─── BROWSER AUTOMATION ───────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_TIMEOUT=30000
BOT_MIN_DELAY_MS=800
BOT_MAX_DELAY_MS=3000
BOT_TYPING_DELAY_MIN=80
BOT_TYPING_DELAY_MAX=220

# ─── EMAIL (SMTP for transactional) ───────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM_NAME="Job Hunter AI"
SMTP_FROM_EMAIL=noreply@jobhunterai.com

# ─── RATE LIMITING ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
MAX_APPLICATIONS_PER_DAY=20
MAX_FOLLOW_UPS_PER_APPLICATION=2
EMAIL_MONITOR_INTERVAL_MS=900000
JOB_SEARCH_INTERVAL_MS=7200000

# ─── LOGGING ──────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── WORKER CONCURRENCY ───────────────────────────────────
SCRAPER_CONCURRENCY=3
BOT_CONCURRENCY=2
AI_MATCH_CONCURRENCY=10
EMAIL_MONITOR_CONCURRENCY=5
NOTIFICATION_CONCURRENCY=20
